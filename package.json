{
  "name": "quickbits-site",
  "version": "1.0.0",
  "private": true,
  "description": "QuickBits — independent product studio. A zero-framework static landing page deployed on Cloudflare Pages.",
  "packageManager": "bun@1.3.11",
  "scripts": {
    "dev": "wrangler pages dev public",
    "pages:create": "wrangler pages project create quickbits-site --production-branch=main",
    "deploy": "wrangler pages deploy public --project-name=quickbits-site",
    "deploy:prod": "wrangler pages deploy public --project-name=quickbits-site --branch=main",
    "fonts": "bash scripts/optimize-fonts.sh"
  },
  "devDependencies": {
    "wrangler": "^4"
  }
}
